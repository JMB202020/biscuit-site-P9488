          <div class="text-[var(--color-ink)] font-bold text-lg mb-1">per day</fullscreen-image.pngdiv>
          <div class="text-[var(--color-ink-soft)] text-sm">for one pussycat</fullscreen-image.pngdiv>
        </fullscreen-image.pngdiv>
