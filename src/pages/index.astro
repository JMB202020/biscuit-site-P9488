          </fullscreen-image.pngdiv>
          <div class="bg-[var(--color-accent-light)] p-3 text-center">
            <p class="font-bold text-[var(--color-ink)] text-sm">🐟 Fish Suite</fullscreen-image.pngp>
          </fullscreen-image.pngdiv>
        </fullscreen-image.pngdiv>
        <div class="overflow-hidden rounded-xl shadow-md group">
          <div class="aspect-square overflow-hidden">
            <img src="/fullscreen-image.pngP9488/fullscreen-image.pngimages/fullscreen-image.pngimg-20250804-wa0003.jpg" alt="Bird Suite" width="500" height="500" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" /fullscreen-image.png>
