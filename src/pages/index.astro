        <div class="overflow-hidden rounded-xl shadow-md group">
          <div class="aspect-square overflow-hidden">
            <img src="/fullscreen-image.pngP9488/fullscreen-image.pngimages/fullscreen-image.pngbuiswc.png" alt="Bumble Suite" width="500" height="500" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" /fullscreen-image.png>
          </fullscreen-image.pngdiv>
          <div class="bg-[var(--color-accent-light)] p-3 text-center">
